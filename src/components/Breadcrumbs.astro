---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
const fullItems = [{ label: 'Home', href: '/' }, ...items];

const schemaItems = fullItems.map((item, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: item.label,
  ...(item.href ? { item: `https://foundationstreeexperts.com${item.href}` } : {}),
}));
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {fullItems.map((item, i) => (
      <li>
        {item.href && i < fullItems.length - 1
          ? <a href={item.href}>{item.label}</a>
          : <span aria-current={i === fullItems.length - 1 ? 'page' : undefined}>{item.label}</span>
        }
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
})} />

<style>
  .breadcrumbs {
    padding: 1rem 0 0;
    font-size: 0.8125rem;
    color: var(--fg-3);
  }
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .breadcrumbs li:not(:last-child)::after {
    content: '›';
    margin-left: 0.25rem;
    color: var(--fg-3);
  }
  .breadcrumbs a {
    color: var(--fg-3);
    text-decoration: none;
  }
  .breadcrumbs a:hover { text-decoration: underline; }
  .breadcrumbs span[aria-current] { color: var(--fg); font-weight: 500; }
</style>

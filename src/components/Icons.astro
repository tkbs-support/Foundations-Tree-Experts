---
interface Props {
  name: string;
  size?: number;
  strokeWidth?: number;
  fill?: string;
  class?: string;
}

const { name, size = 24, strokeWidth = 1.6, fill, class: className } = Astro.props;

const icons: Record<string, string> = {
  tree: '<path d="M12 21v-5"/><path d="M8 16c-2.5 0-4-1.5-4-3.5 0-1.5 1-2.5 2-3 -0.5-0.8-1-2-0.5-3.5C6 4.5 7.5 4 9 4.5 10 3 11 2.5 12 2.5s2 0.5 3 2c1.5-0.5 3 0 3.5 1.5 0.5 1.5 0 2.7-0.5 3.5 1 0.5 2 1.5 2 3C20 14.5 18.5 16 16 16z"/>',
  chainsaw: '<path d="M3 8h10l2-2h4v4h-4l-2 2H3z"/><path d="M6 12v3M9 12v3M12 12v3"/><circle cx="17" cy="16" r="2"/>',
  stump: '<ellipse cx="12" cy="8" rx="8" ry="3"/><path d="M4 8v6c0 1.5 3.5 3 8 3s8-1.5 8-3V8"/><path d="M10 8v6M14 8v6"/>',
  storm: '<path d="M5 15a4 4 0 010-8 6 6 0 0111.5-2 5 5 0 012 9.5"/><path d="M11 14l-2 5h3l-2 4"/>',
  branches: '<path d="M12 22V6"/><path d="M12 10l-4-4M12 14l4-4M12 18l-4-4"/>',
  hedge: '<rect x="3" y="10" width="18" height="10" rx="2"/><path d="M6 10V6M10 10V4M14 10V5M18 10V7"/>',
  shield: '<path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/><path d="M9 12l2 2 4-4"/>',
  badge: '<circle cx="12" cy="9" r="6"/><path d="M9 15l-2 6 5-3 5 3-2-6"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  leaf: '<path d="M5 19c0-8 6-14 14-14 0 8-6 14-14 14z"/><path d="M5 19l7-7"/>',
  phone: '<path d="M4 4h4l2 5-2.5 1.5a11 11 0 006 6L15 14l5 2v4a1 1 0 01-1 1A16 16 0 013 5a1 1 0 011-1z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  star: '<path d="M12 2l3 6.5 7 1-5 4.9 1.2 7L12 18l-6.2 3.4L7 14.4 2 9.5l7-1z"/>',
  check: '<path d="M5 13l4 4 10-10"/>',
  close: '<path d="M6 6l12 12M18 6L6 18"/>',
  sparkle: '<path d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5L18 18M6 18l2.5-2.5M15.5 8.5L18 6"/>',
  bolt: '<path d="M13 3L4 14h7l-1 7 9-11h-7z"/>',
  compass: '<circle cx="12" cy="12" r="9"/><path d="M16 8l-2 6-6 2 2-6z"/>',
  pin: '<path d="M12 21s7-7 7-12a7 7 0 10-14 0c0 5 7 12 7 12z"/><circle cx="12" cy="9" r="2.5"/>',
  menu: '<path d="M4 6h16M4 12h16M4 18h16"/>',
};

const isFilled = name === 'star';
const svgFill = fill || (isFilled ? 'currentColor' : 'none');
const svgStroke = isFilled ? 0.5 : strokeWidth;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={svgFill}
  stroke="currentColor"
  stroke-width={svgStroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  set:html={icons[name] || ''}
/>

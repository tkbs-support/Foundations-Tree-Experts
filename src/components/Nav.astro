---
import Icons from './Icons.astro';
import services from '../data/services.json';
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <img src="/images/logo-shield.png" alt="Foundations Tree Experts" style="width:38px;height:38px;object-fit:contain;" />
      <div>
        <div>Foundations</div>
        <div class="brand-small">Tree Experts · <span style="white-space:nowrap;">Ann Arbor, MI</span></div>
      </div>
    </a>

    <div class="nav-links">
      <!-- Services dropdown -->
      <div class="nav-dropdown-wrap">
        <a href="/services/" class="hover-underline nav-dropdown-trigger">
          Services
        </a>
        <div class="nav-dropdown">
          <div class="nav-dropdown-inner">
            <a href="/services/" class="nav-dropdown-heading">All Services</a>
            {services.map(s => (
              <a href={`/services/${s.slug}/`} class="nav-dropdown-item">
                <span class="nav-dropdown-title">{s.title}</span>
                <span class="nav-dropdown-tag">{s.tag}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <a href="/#area" class="hover-underline">Service Areas</a>
      <a href="/reviews/" class="hover-underline">Reviews</a>
      <a href="/#about" class="hover-underline">About</a>
      <a href="/#faq" class="hover-underline">FAQ</a>
    </div>

    <div class="nav-right">
      <a class="nav-phone hover-underline" href="tel:17344743336">
        <Icons name="phone" size={16} /> (734) 474-3336
      </a>
      <button class="btn btn-primary" data-open-wizard style="padding:0.65rem 1.1rem;font-size:0.88rem;">
        Free quote
      </button>
      <button class="nav-burger" aria-label="Menu" aria-expanded="false">
        <Icons name="menu" size={18} />
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div class="mobile-menu" aria-hidden="true">
  <div class="mobile-menu-links">
    <!-- Services expandable -->
    <div class="mobile-expand">
      <button class="mobile-expand-trigger">Services <Icons name="arrow" size={12} class="mobile-expand-icon" /></button>
      <div class="mobile-expand-content">
        <a href="/services/">All Services</a>
        {services.map(s => (
          <a href={`/services/${s.slug}/`}>{s.title}</a>
        ))}
      </div>
    </div>

    <a href="/#area">Service Areas</a>
    <a href="/reviews/">Reviews</a>
    <a href="/#about">About</a>
    <a href="/#faq">FAQ</a>
  </div>
  <div class="mobile-menu-cta">
    <a class="btn btn-primary" href="tel:17344743336" style="justify-content:center;">
      <Icons name="phone" size={16} /> (734) 474-3336
    </a>
    <button class="btn btn-primary" data-open-wizard style="justify-content:center;">
      Book a free quote <Icons name="arrow" />
    </button>
  </div>
</div>

<script>
  const nav = document.querySelector('.nav');
  const burger = document.querySelector('.nav-burger');
  const mobileMenu = document.querySelector('.mobile-menu');
  let savedScrollY = 0;

  function toggleMenu() {
    const isOpen = mobileMenu.classList.contains('open');
    if (isOpen) {
      mobileMenu.classList.remove('open');
      burger.setAttribute('aria-expanded', 'false');
      document.body.style.position = '';
      document.body.style.width = '';
      document.body.style.top = '';
      window.scrollTo(0, savedScrollY);
    } else {
      savedScrollY = window.scrollY;
      mobileMenu.classList.add('open');
      burger.setAttribute('aria-expanded', 'true');
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
      document.body.style.top = `-${savedScrollY}px`;
    }
  }

  burger?.addEventListener('click', toggleMenu);
  document.querySelectorAll('.mobile-menu-links > a').forEach(link => {
    link.addEventListener('click', () => {
      if (mobileMenu.classList.contains('open')) toggleMenu();
    });
  });
  document.querySelectorAll('.mobile-expand-content a').forEach(link => {
    link.addEventListener('click', () => {
      if (mobileMenu.classList.contains('open')) toggleMenu();
    });
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && mobileMenu.classList.contains('open')) toggleMenu();
  });

  // Mobile expandable sections
  document.querySelectorAll('.mobile-expand-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('.mobile-expand');
      parent.classList.toggle('open');
    });
  });

  // Scroll: add border on scroll, smart sticky header
  let lastY = 0;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y > lastY && y > 80) {
      nav.style.transform = 'translateY(-100%)';
    } else {
      nav.style.transform = 'translateY(0)';
    }
    if (y > 8) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
    lastY = y;
  }, { passive: true });
</script>

<style is:global>
  .nav { transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1); }

  /* Dropdown container */
  .nav-dropdown-wrap {
    position: relative;
  }
  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 200ms ease, transform 200ms ease;
    z-index: 100;
    padding-top: 12px;
  }
  .nav-dropdown-wrap:hover .nav-dropdown,
  .nav-dropdown-wrap:focus-within .nav-dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  /* Services dropdown */
  .nav-dropdown-inner {
    background: var(--bg);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    padding: 0.5rem;
    min-width: 240px;
  }
  .nav-dropdown-heading {
    display: block;
    padding: 0.6rem 0.75rem;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0.25rem;
  }
  .nav-dropdown-heading:hover { color: var(--forest-700); }
  .nav-dropdown-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 0.75rem;
    text-decoration: none;
    color: var(--fg);
    border-radius: var(--radius-sm);
    transition: background 150ms ease;
    font-size: 0.88rem;
  }
  .nav-dropdown-item:hover { background: var(--bg-2); }
  .nav-dropdown-title { font-weight: 500; }
  .nav-dropdown-tag {
    font-family: var(--ff-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-3);
    white-space: nowrap;
  }

  /* Mega menu (service areas) */
  .nav-mega {
    left: 50%;
    min-width: 560px;
  }
  .nav-mega-inner {
    background: var(--bg);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    padding: 1.25rem 1.5rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .nav-mega-county {
    font-family: var(--ff-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-3);
    margin-bottom: 0.5rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--rule);
  }
  .nav-mega-col a {
    display: block;
    padding: 0.3rem 0;
    text-decoration: none;
    color: var(--fg-2);
    font-size: 0.88rem;
    transition: color 150ms ease;
  }
  .nav-mega-col a:hover { color: var(--forest-700); }
  .nav-mega-viewall {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    padding: 0.75rem;
    margin-top: 0.5rem;
    background: var(--bg);
    border: 1px solid var(--rule);
    border-top: none;
    border-radius: 0 0 var(--radius) var(--radius);
    box-shadow: var(--shadow-lg);
    text-decoration: none;
    color: var(--forest-700);
    font-weight: 600;
    font-size: 0.85rem;
    transition: background 150ms ease;
  }
  .nav-mega-viewall:hover { background: var(--bg-2); }

  /* Mobile expandable sections */
  .mobile-expand-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.75rem 0;
    background: none;
    border: none;
    font: inherit;
    font-size: 1.1rem;
    color: var(--cream-50);
    cursor: pointer;
  }
  .mobile-expand-icon {
    transform: rotate(90deg);
    transition: transform 200ms ease;
    opacity: 0.5;
  }
  .mobile-expand.open .mobile-expand-icon {
    transform: rotate(-90deg);
  }
  .mobile-expand-content {
    display: none;
    padding: 0 0 0.5rem 1rem;
  }
  .mobile-expand.open .mobile-expand-content {
    display: block;
  }
  .mobile-expand-content a {
    display: block;
    padding: 0.4rem 0;
    color: color-mix(in oklch, var(--cream-50) 80%, transparent);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .mobile-expand-content a:first-child {
    font-weight: 600;
    color: var(--cream-50);
    margin-bottom: 0.25rem;
  }
  .mobile-county-label {
    font-family: var(--ff-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--cream-50) 40%, transparent);
    margin-top: 0.75rem;
    margin-bottom: 0.25rem;
  }

  /* Hide dropdowns on mobile */
  @media (max-width: 900px) {
    .nav-dropdown-wrap .nav-dropdown { display: none !important; }
  }
</style>

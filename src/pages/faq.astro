---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABand from '../components/CTABand.astro';
import TrustStrip from '../components/TrustStrip.astro';
import faqs from '../data/faqs.json';
---

<PageLayout
  title="FAQ — Tree Service Questions Answered · Foundations Tree Experts"
  description="Frequently asked questions about tree removal, trimming, stump grinding, and emergency services in Ann Arbor, MI. Get straight answers from Foundations Tree Experts."
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    })} />
  </Fragment>

  <div class="container">
    <Breadcrumbs items={[{ label: 'FAQ' }]} />
  </div>

  <section class="section">
    <div class="container">
      <div class="faq-grid">
        <div class="reveal">
          <div class="eyebrow">Questions</div>
          <h1 class="display-lg" style="margin-top:1rem;">The straight answers.</h1>
          <p class="lead" style="margin-top:1rem;">
            Can't find what you need? Call us directly at{' '}
            <a class="hover-underline" style="color:var(--forest-700);font-weight:600;" href="tel:17344743336">(734) 474-3336</a>.
          </p>
        </div>
        <div class="reveal">
          <FAQAccordion faqs={faqs} />
        </div>
      </div>
    </div>
  </section>

  <CTABand headline="Have a question we didn't cover?" buttonText="Get my free quote" />
  <TrustStrip />
</PageLayout>

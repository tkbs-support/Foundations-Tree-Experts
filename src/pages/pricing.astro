---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icons from '../components/Icons.astro';
import TrustStrip from '../components/TrustStrip.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const pricingFaqs = [
  { q: "How much does tree removal cost in Ann Arbor?", a: "Most residential tree removals in Ann Arbor and Southeast Michigan run between $450 and $2,500, depending on the tree's size, species, and proximity to structures or power lines. Small trees under 30 feet often start around $450, while large mature hardwoods or trees requiring rigging near a home can reach $2,500 or more. Every quote is firm and free after an on-site assessment." },
  { q: "Can you give me an exact price over the phone?", a: "We can give a ballpark range, but accurate pricing requires an on-site assessment. Tree size, species, location relative to structures, access for equipment, and complexity all affect the final quote. Our on-site assessments are always free." },
  { q: "Is there a charge for the estimate?", a: "No — every estimate is free. We walk the property, inspect the trees, and provide a firm written quote." },
  { q: "Do you offer payment plans?", a: "For larger jobs, we can discuss payment options. Call us at (734) 474-3336 to talk through the details." },
  { q: "Does homeowner's insurance cover tree removal?", a: "In many cases, yes — especially if a tree falls due to a storm or sudden event. Insurance typically covers removal when a tree damages a structure, blocks access, or poses an immediate hazard. Contact your insurance company to discuss your specific coverage. We provide invoices for all completed work." },
];

/* ── Typical price ranges — Ann Arbor / SE Michigan market rates ──
   Ballpark guidance only. Every job is quoted firm and free on-site. */
const priceGuide = [
  { name: "Tree Removal",            slug: "tree-removal",            range: "$450 – $2,500+",       min: 450,  max: 2500, factors: "Tree size, species, proximity to structures, equipment access" },
  { name: "Trimming & Pruning",      slug: "trimming-pruning",        range: "$250 – $1,200",        min: 250,  max: 1200, factors: "Tree size, number of trees, canopy density, height" },
  { name: "Stump Grinding",          slug: "stump-grinding",          range: "$100 – $400 / stump",  min: 100,  max: 400,  factors: "Stump diameter, root system, access, number of stumps" },
  { name: "Emergency Storm Response",slug: "emergency-storm-response",range: "$500 – $3,000+",       min: 500,  max: 3000, factors: "Severity, structural involvement, access, equipment needed" },
  { name: "Crane-Assisted Removal",  slug: "crane-assisted-removal",  range: "$1,200 – $5,000+",     min: 1200, max: 5000, factors: "Crane size needed, tree weight, over-structure complexity" },
  { name: "Lot & Land Clearing",     slug: "lot-land-clearing",       range: "$1,500 – $5,000+ / acre", min: 1500, max: 5000, factors: "Acreage, tree density, stump removal, debris hauling" },
];

const offerCatalogSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://foundationstreeexperts.com/#business",
  "name": "Foundations Tree Experts",
  "makesOffer": priceGuide.map((p) => ({
    "@type": "Offer",
    "itemOffered": {
      "@type": "Service",
      "name": p.name,
      "provider": { "@id": "https://foundationstreeexperts.com/#business" },
      "areaServed": { "@type": "State", "name": "Michigan" },
    },
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "USD",
      "minPrice": p.min,
      "maxPrice": p.max,
    },
    "priceCurrency": "USD",
    "description": `Typical range for ${p.name.toLowerCase()} in Ann Arbor and Southeast Michigan. Firm quote provided free after an on-site assessment.`,
  })),
};
---

<PageLayout
  title="Free Estimates — What Affects Your Tree Service Quote · Foundations Tree Experts"
  description="See what factors affect your tree removal, trimming, and stump grinding quote in Ann Arbor and Southeast Michigan. Free on-site estimates — no surprises."
  footerCtaHeadline="Ready for your free estimate?"
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": pricingFaqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify(offerCatalogSchema)} />
  </Fragment>

  <div class="container">
    <Breadcrumbs items={[{ label: 'Pricing' }]} />
  </div>

  <section class="section">
    <div class="container">
      <div class="eyebrow">Pricing</div>
      <h1 class="display-lg" style="margin-top:1rem;">Tree service pricing in Ann Arbor</h1>
      <p class="lead" style="margin-top:1rem;max-width:680px;">
        Most residential tree work in Ann Arbor and Southeast Michigan falls in the ranges below. Every job is different, so we confirm your firm price free with an on-site assessment — no surprises, no hidden fees.
      </p>

      <div style="margin-top:2.5rem;overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:0.95rem;">
          <thead>
            <tr style="border-bottom:2px solid var(--rule-2);text-align:left;">
              <th style="padding:0.75rem 1rem;font-weight:600;">Service</th>
              <th style="padding:0.75rem 1rem;font-weight:600;white-space:nowrap;">Typical Range*</th>
              <th style="padding:0.75rem 1rem;font-weight:600;">What Affects Your Quote</th>
            </tr>
          </thead>
          <tbody>
            {priceGuide.map((p, i) => (
              <tr style={i < priceGuide.length - 1 ? "border-bottom:1px solid var(--rule);" : ""}>
                <td style="padding:0.75rem 1rem;font-weight:500;"><a href={`/services/${p.slug}/`} style="color:inherit;text-decoration:none;">{p.name}</a></td>
                <td style="padding:0.75rem 1rem;color:var(--fg);font-weight:600;white-space:nowrap;">{p.range}</td>
                <td style="padding:0.75rem 1rem;color:var(--fg-2);">{p.factors}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="font-size:0.8125rem;color:var(--fg-3);margin-top:1rem;font-style:italic;">
        *Typical ranges for residential jobs in the Ann Arbor / Southeast Michigan area, shown as guidance only. Your firm price is set free after an on-site assessment — no surprises, no hidden fees.
      </p>
    </div>
  </section>

  <section class="section" style="background:var(--bg-2);">
    <div class="container">
      <h2 class="display-md" style="margin-bottom:1.5rem;">What's included in every quote</h2>
      <div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:1.5rem;">
        {[
          { icon: 'check', text: 'Free on-site assessment' },
          { icon: 'check', text: 'Written quote — no surprises' },
          { icon: 'check', text: 'Full debris cleanup & haul' },
          { icon: 'check', text: 'Stump grinding (if requested)' },
          { icon: 'check', text: 'Property walk-through before we leave' },
          { icon: 'check', text: 'Liability & workers\' comp coverage' },
        ].map(item => (
          <div style="display:flex;align-items:flex-start;gap:0.75rem;">
            <div style="color:var(--forest-700);flex-shrink:0;margin-top:2px;">
              <Icons name={item.icon} size={18} strokeWidth={2.5} />
            </div>
            <span>{item.text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:760px;">
      <h2 class="display-md" style="margin-bottom:1.5rem;">Pricing FAQ</h2>
      <FAQAccordion faqs={pricingFaqs} />
    </div>
  </section>

  <TrustStrip />
</PageLayout>

<style>
  @media (max-width: 700px) {
    div[style*="grid-template-columns: repeat(3"] {
      grid-template-columns: 1fr !important;
    }
    table { font-size: 0.85rem; }
  }
</style>

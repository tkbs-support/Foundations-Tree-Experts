---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icons from '../components/Icons.astro';
import CTABand from '../components/CTABand.astro';
import TrustStrip from '../components/TrustStrip.astro';
---

<PageLayout
  title="About Foundations Tree Experts — 26+ Years in Ann Arbor, MI"
  description="Meet David Paga and the Foundations crew. 26+ years of insured tree care in Southeast Michigan with ISA Certified Arborist Evan Little on staff."
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "mainEntity": { "@id": "https://foundationstreeexperts.com/#business" }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "David Paga",
        "jobTitle": "Founder",
        "worksFor": { "@id": "https://foundationstreeexperts.com/#business" },
        "knowsAbout": ["Tree Removal", "Arboriculture", "Storm Damage Response", "Land Clearing"]
      },
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Evan Little",
        "jobTitle": "Certified Arborist",
        "worksFor": { "@id": "https://foundationstreeexperts.com/#business" },
        "hasCredential": {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "ISA Certified Arborist",
          "identifier": "MI-4446A",
          "recognizedBy": { "@type": "Organization", "name": "International Society of Arboriculture" }
        },
        "knowsAbout": ["Tree Health Assessment", "Pruning Standards", "Disease Diagnosis", "Risk Assessment"]
      }
    ])} />
  </Fragment>

  <div class="container">
    <Breadcrumbs items={[{ label: 'About Us' }]} />
  </div>

  <section class="section">
    <div class="container">
      <div class="eyebrow">Our story</div>
      <h1 class="display-lg" style="margin-top:1rem;">26+ years. One standard.<br /><em style="font-style:italic;color:var(--forest-700);font-weight:400;">Every single job.</em></h1>
      <p class="lead" style="margin-top:1.25rem;max-width:680px;">
        Foundations Tree Experts was built on a simple idea: treat every property like it's your own, and every client like a neighbor.
      </p>
    </div>
  </section>

  <!-- Founder -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="founder-grid">
        <div class="reveal founder-media">
          <img src="/images/david-portrait.webp" width="800" height="800" alt="David Paga, founder of Foundations Tree Experts, up in a tree on a job site" loading="lazy" />
          <div class="founder-sig">
            <div class="sig-name">David Paga</div>
            <div class="sig-role">Founder · 26+ years</div>
          </div>
        </div>
        <div class="reveal founder-body">
          <h2 class="display-md" style="margin-bottom:1.25rem;">Meet David</h2>
          <p>With more than 26 years of service across Ann Arbor and Southeast Michigan, David Paga and the Foundations crew bring one mission and one standard to every job — no matter the size.</p>
          <blockquote>"Treat every property like it's our own, and every client like a neighbor."</blockquote>
          <p>Alongside his wife Julia and their seven kids, David built this company on the same values he brings home every night — hard work, honesty, and taking care of the people around you. That's why Foundations treats every yard with the same care they'd give their own.</p>
          <p>David's love for the industry goes beyond just removing trees — it's about protecting homes, helping families feel safe, and taking pride in difficult work that requires skill, experience, and precision. From hazardous removals to careful pruning and storm cleanup, he genuinely enjoys the challenge and craftsmanship that comes with professional tree care.</p>
          <p>It means pulling up on time, walking the property before we quote, and calling out problems even when they're outside our scope. It means having a certified arborist on staff — and leaving every job cleaner and straighter than we found it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Arborist -->
  <section class="section trust noise">
    <div class="container" style="position:relative;z-index:2;">
      <div class="reveal">
        <div class="eyebrow">Our arborist</div>
        <h2 class="display-lg" style="margin-top:1rem;">Evan Little, ISA Certified Arborist</h2>
        <p class="lead" style="margin-top:1rem;max-width:680px;">
          Credential: <strong>MI-4446A</strong> · International Society of Arboriculture
        </p>
      </div>
      <div class="reveal" style="margin-top:2rem;max-width:680px;">
        <p>Evan brings certified expertise to every assessment and job plan. Whether it's diagnosing oak wilt, recommending targeted pruning instead of removal, or evaluating root stability on a mature maple, Evan's assessments ensure the right call is made — every time.</p>
        <p style="margin-top:1rem;">Having an ISA Certified Arborist on staff means Foundations doesn't guess. We know which trees need to come down, which can be saved, and exactly how to handle complex removals safely.</p>
      </div>
    </div>
  </section>

  <CTABand headline="Want us on your property?" buttonText="Get my free estimate" />

  <TrustStrip />
</PageLayout>

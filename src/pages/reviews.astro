---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icons from '../components/Icons.astro';

/* ── Video testimonials ──────────────────────────────────────────
   Add YouTube video IDs below. Section hides when the array is empty.
   Example: { id: 'dQw4w9WgXcQ', title: 'Customer review — tree removal' }
   ──────────────────────────────────────────────────────────────── */
const videos: { id: string; title: string }[] = [
  { id: 'PLACEHOLDER_1', title: 'Customer video testimonial' },
  { id: 'PLACEHOLDER_2', title: 'Customer video testimonial' },
  { id: 'PLACEHOLDER_3', title: 'Customer video testimonial' },
  { id: 'PLACEHOLDER_4', title: 'Customer video testimonial' },
];

/* ── Written testimonials (build-time import for SEO / AEO) ───── */
// @ts-ignore — JSON import from public directory
import allTestimonials from '../../public/testimonials.json';
const pageOnlyReviews = [
  {
    quote: 'We had a 70 ft maple tree and a 45 ft maple tree removed this spring, and David and his crew completed the entire project flawlessly.',
    name: 'Justin Hines',
    stars: 5,
    source: 'google',
  },
];
const reviews = [
  ...pageOnlyReviews,
  ...(allTestimonials as any[]).filter(
    (t) => t.quote && !t.quote.startsWith('PASTE'),
  ),
];
const featured = reviews[0];
const rest = reviews.slice(1);

const GOOGLE_REVIEWS_URL =
  'https://www.google.com/search?q=foundations+tree+experts#lrd=0x883caf35d7680699:0x29679feb5671996f,1,,,,';

/* ── Structured data — individual Review + AggregateRating ────── */
const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Foundations Tree Experts',
  '@id': 'https://foundationstreeexperts.com/#business',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '90',
    bestRating: '5',
  },
  review: reviews.map((r) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.name },
    reviewRating: {
      '@type': 'Rating',
      ratingValue: String(r.stars || 5),
      bestRating: '5',
    },
    reviewBody: r.quote,
    ...(r.source === 'google' && {
      publisher: { '@type': 'Organization', name: 'Google' },
    }),
  })),
};
---

<PageLayout
  title="Customer Reviews — Foundations Tree Experts · Ann Arbor, MI"
  description="Read 90+ five-star reviews from Ann Arbor and Southeast Michigan homeowners. See why customers trust Foundations Tree Experts for tree removal, trimming, and emergency storm response."
  footerCtaHeadline="Ready for a crew you can trust?"
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
  </Fragment>

  <div class="container">
    <Breadcrumbs items={[{ label: 'Reviews' }]} />
  </div>

  <!-- ── Hero ──────────────────────────────────────────────────── -->
  <section class="section rv-hero">
    <div class="container">
      <div class="rv-hero-layout">
        <div class="rv-hero-copy">
          <div class="eyebrow">Trusted by homeowners</div>
          <h1 class="display-lg" style="margin-top:0.75rem;">
            Don't just take our word for it.
          </h1>
          <p class="lead" style="margin-top:1rem;max-width:38ch;">
            Hear from Ann Arbor and Southeast Michigan families who trust our crew's 26+ years of experience.
          </p>
          <div class="rv-hero-actions">
            <a
              href={GOOGLE_REVIEWS_URL}
              target="_blank"
              rel="noopener"
              class="btn btn-primary"
            >
              See all reviews on Google <Icons name="arrow" size={14} />
            </a>
          </div>
        </div>

        <div class="rv-hero-badge reveal">
          <div class="rv-badge-score">5.0</div>
          <div class="rv-badge-stars">
            {Array.from({ length: 5 }).map(() => <Icons name="star" size={20} />)}
          </div>
          <div class="rv-badge-label">based on 90+ reviews</div>
          <div class="rv-badge-source">
            <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59A14.5 14.5 0 019.5 24c0-1.59.28-3.14.76-4.59l-7.98-6.19A23.99 23.99 0 000 24c0 3.77.9 7.35 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            Google Reviews
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Video Testimonials ───────────────────────────────────── -->
  {videos.length > 0 && (
    <section class="section rv-videos">
      <div class="container">
        <div class="eyebrow">Video testimonials</div>
        <h2 class="display-md" style="margin-top:0.75rem;">
          Hear directly from our customers
        </h2>

        <div class="video-grid">
          {videos.map((v) => (
            <div class={`yt-facade ${v.id.startsWith('PLACEHOLDER') ? 'yt-placeholder' : ''}`} data-videoid={v.id}>
              {!v.id.startsWith('PLACEHOLDER') && (
                <img
                  src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`}
                  alt={v.title}
                  loading="lazy"
                  width="480"
                  height="360"
                />
              )}
              {v.id.startsWith('PLACEHOLDER') && (
                <div class="yt-placeholder-inner">
                  <Icons name="tree" size={40} />
                  <span>Video testimonial coming soon</span>
                </div>
              )}
              <button class={`yt-play ${v.id.startsWith('PLACEHOLDER') ? 'yt-play--disabled' : ''}`} aria-label={`Play: ${v.title}`}>
                <svg width="68" height="48" viewBox="0 0 68 48">
                  <path
                    d="M66.5 7.7c-.8-2.9-3-5.2-5.9-6C55.3 0 34 0 34 0S12.7 0 7.4 1.7c-2.9.8-5.1 3.1-5.9 6C0 13 0 24 0 24s0 11 1.5 16.3c.8 2.9 3 5.2 5.9 6C12.7 48 34 48 34 48s21.3 0 26.6-1.7c2.9-.8 5.1-3.1 5.9-6C68 35 68 24 68 24s0-11-1.5-16.3z"
                    fill="red"
                  />
                  <path d="M27 34l18-10-18-10z" fill="#fff" />
                </svg>
              </button>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Featured Review ──────────────────────────────────────── -->
  {featured && (
    <section class="section rv-featured">
      <div class="container">
        <div class="rv-pullquote reveal">
          <blockquote>
            <p>{featured.quote}</p>
          </blockquote>
          <div class="rv-pullquote-who">
            <div class="rv-pullquote-stars">
              {Array.from({ length: featured.stars || 5 }).map(() => <Icons name="star" size={14} />)}
            </div>
            <span class="rv-pullquote-name">{featured.name}</span>
            {featured.source === 'google' && (
              <span class="rv-source-tag">
                <svg width="14" height="14" viewBox="0 0 48 48" aria-hidden="true">
                  <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                  <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                  <path fill="#FBBC05" d="M10.53 28.59A14.5 14.5 0 019.5 24c0-1.59.28-3.14.76-4.59l-7.98-6.19A23.99 23.99 0 000 24c0 3.77.9 7.35 2.56 10.78l7.97-6.19z"/>
                  <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                </svg>
                Google
              </span>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── Review Cards (light background — distinct from homepage) ── -->
  <section class="section rv-grid-section">
    <div class="container">
      <div class="rv-cards">
        {rest.map((t) => (
          <div class="rv-card reveal">
            <div class="rv-card-stars">
              {Array.from({ length: t.stars || 5 }).map(() => <Icons name="star" size={13} />)}
              {t.source === 'google' && (
                <span class="rv-source-tag">
                  <svg width="13" height="13" viewBox="0 0 48 48" aria-hidden="true">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59A14.5 14.5 0 019.5 24c0-1.59.28-3.14.76-4.59l-7.98-6.19A23.99 23.99 0 000 24c0 3.77.9 7.35 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                  </svg>
                  Google
                </span>
              )}
            </div>
            <p class="rv-card-quote">{t.quote}</p>
            <div class="rv-card-author">
              <div class="rv-card-avatar">{(t.name || '?')[0]}</div>
              <span class="rv-card-name">{t.name}</span>
              {t.location && <span class="rv-card-loc">· {t.location}</span>}
            </div>
          </div>
        ))}
      </div>

      <div style="text-align:center;margin-top:3rem;">
        <a
          href={GOOGLE_REVIEWS_URL}
          target="_blank"
          rel="noopener"
          class="btn btn-primary"
        >
          Read all 90+ reviews on Google <Icons name="arrow" size={14} />
        </a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────────── */
  .rv-hero {
    padding-bottom: clamp(2.25rem, 4.5vw, 5rem);
  }
  .rv-hero-layout {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }
  .rv-hero-copy {
    flex: 1;
    min-width: 0;
  }
  .rv-hero-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.75rem;
    flex-wrap: wrap;
  }
  .rv-hero-badge {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 2rem 2.5rem;
    border-radius: var(--radius-lg);
    background: var(--forest-900);
    color: var(--cream-50);
    text-align: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }
  .rv-badge-score {
    font-family: var(--ff-display);
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .rv-badge-stars {
    display: flex;
    gap: 3px;
    color: var(--bark-300);
  }
  .rv-badge-label {
    font-family: var(--ff-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in oklch, var(--cream-50) 55%, transparent);
    margin-top: 0.25rem;
  }
  .rv-badge-source {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--ff-body);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--cream-50);
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid color-mix(in oklch, var(--cream-50) 15%, transparent);
  }
  @media (max-width: 800px) {
    .rv-hero-layout {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
    }
    .rv-hero-badge {
      align-self: stretch;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem 1.5rem;
      padding: 1.25rem 1.5rem;
    }
    .rv-badge-score { font-size: 2.5rem; }
    .rv-badge-label { margin-top: 0; }
    .rv-badge-source { margin-top: 0; padding-top: 0; border-top: none; border-left: 1px solid color-mix(in oklch, var(--cream-50) 15%, transparent); padding-left: 1rem; }
  }

  /* ── Video section ────────────────────────────────────────── */
  .rv-videos {
    background: var(--bg-2);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .video-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  @media (max-width: 700px) {
    .video-grid { grid-template-columns: 1fr; }
  }

  /* ── YouTube facade ───────────────────────────────────────── */
  .yt-facade {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    background: var(--char-900);
  }
  .yt-facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    transition: opacity 200ms ease;
  }
  .yt-facade:hover img { opacity: 1; }
  .yt-facade :global(iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .yt-play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: none;
    border: none;
    cursor: pointer;
    transition: transform 200ms ease;
  }
  .yt-play:hover { transform: scale(1.1); }
  .yt-play svg { filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.4)); }

  /* YouTube placeholder */
  .yt-placeholder {
    background: linear-gradient(135deg, var(--forest-900), var(--forest-800));
    cursor: default;
  }
  .yt-placeholder-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: color-mix(in oklch, var(--cream-50) 40%, transparent);
  }
  .yt-placeholder-inner span {
    font-family: var(--ff-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .yt-play--disabled {
    opacity: 0.25;
    pointer-events: none;
  }

  /* ── Featured pull-quote ──────────────────────────────────── */
  .rv-featured {
    border-bottom: 1px solid var(--rule);
  }
  .rv-pullquote {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .rv-pullquote blockquote {
    margin: 0;
    padding: 0;
  }
  .rv-pullquote blockquote p {
    font-family: var(--ff-display);
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    line-height: 1.5;
    font-weight: 400;
    color: var(--fg);
    text-wrap: pretty;
  }
  .rv-pullquote blockquote p::before {
    content: "\201C";
    color: var(--forest-600);
    font-size: 1.4em;
    line-height: 0;
    vertical-align: -0.2em;
    margin-right: 0.05em;
  }
  .rv-pullquote blockquote p::after {
    content: "\201D";
    color: var(--forest-600);
    font-size: 1.4em;
    line-height: 0;
    vertical-align: -0.2em;
    margin-left: 0.05em;
  }
  .rv-pullquote-who {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .rv-pullquote-stars {
    display: flex;
    gap: 2px;
    color: var(--forest-700);
  }
  .rv-pullquote-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--fg);
  }

  /* ── Google source tag (shared) ───────────────────────────── */
  .rv-source-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--ff-mono);
    font-size: 0.6875rem;
    color: var(--fg-3);
    letter-spacing: 0.03em;
    margin-left: auto;
  }

  /* ── Review cards (light bg — different from homepage dark) ── */
  .rv-grid-section {
    background: var(--bg);
  }
  .rv-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 800px) {
    .rv-cards { grid-template-columns: 1fr; }
  }
  .rv-card {
    background: var(--bg);
    border: 1px solid var(--rule);
    border-left: 4px solid var(--forest-700);
    border-radius: var(--radius);
    padding: 1.5rem 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 200ms ease, transform 200ms ease;
  }
  .rv-card:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }
  .rv-card-stars {
    display: flex;
    align-items: center;
    gap: 2px;
    color: var(--forest-700);
  }
  .rv-card-quote {
    font-family: var(--ff-display);
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--fg);
    text-wrap: pretty;
  }
  .rv-card-author {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--rule);
  }
  .rv-card-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--forest-100);
    color: var(--forest-800);
    display: grid;
    place-items: center;
    font-weight: 600;
    font-size: 0.75rem;
    font-family: var(--ff-mono);
    flex-shrink: 0;
  }
  .rv-card-name {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--fg);
  }
  .rv-card-loc {
    font-family: var(--ff-mono);
    font-size: 0.6875rem;
    color: var(--fg-3);
  }
</style>

<script>
  document.querySelectorAll('.yt-facade').forEach((el) => {
    el.addEventListener('click', () => {
      const id = (el as HTMLElement).dataset.videoid;
      if (!id || id.startsWith('PLACEHOLDER')) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.setAttribute('allowfullscreen', '');
      el.innerHTML = '';
      el.appendChild(iframe);
    });
  });
</script>

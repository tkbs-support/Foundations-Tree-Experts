---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTABand from '../../components/CTABand.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import services from '../../data/services.json';
---

<PageLayout
  title="Tree Services in Ann Arbor & Southeast Michigan — Foundations Tree Experts"
  description="Professional tree removal, trimming, stump grinding, emergency storm response, crane-assisted removal, and lot clearing. ISA Certified Arborist on staff. Free estimates."
>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Services' }]} />
  </div>

  <section class="section">
    <div class="container">
      <div class="eyebrow">Our services</div>
      <h1 class="display-lg" style="margin-top:1rem;">
        <span class="sr-only">Tree Services in Ann Arbor, MI — </span>
        Six services. One crew. Done right.
      </h1>
      <p class="lead" style="margin-top:1rem;max-width:680px;">
        From a single leaning maple to a full lot clear, every job is backed by full liability coverage and an ISA Certified Arborist on staff.
      </p>

      <div class="svc-grid" style="margin-top:2.5rem;">
        {services.map((s, i) => (
          <ServiceCard
            title={s.title}
            desc={s.desc}
            tag={s.tag}
            slug={s.slug}
            featured={i === 0}
          />
        ))}
      </div>
    </div>
  </section>

  <CTABand headline="Not sure which service you need?" buttonText="Get my free assessment" />
  <TrustStrip />
</PageLayout>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0;
    margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }
</style>
